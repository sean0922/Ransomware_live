# Local Docker PostgreSQL from the parent project:
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5433
POSTGRES_DB=ransomware_live
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

